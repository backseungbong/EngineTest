<Window x:Class="JHApp.ECDIS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JHApp.ECDIS"
        xmlns:vm="clr-namespace:JHApp.ECDIS.ViewModels"
        xmlns:gesture="clr-namespace:JHLib.WPFUtil.Gesture;assembly=JHLib.WPFUtil"
        xmlns:util="clr-namespace:JHLib.WPFUtil;assembly=JHLib.WPFUtil"
        mc:Ignorable="d"
        Title="MainWindow" Height="1080" Width="1920">
    <Grid >
        <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
            <util:ViewGraphicsLayer x:Name="ViewGraphicsLayer" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
            <gesture:GesturePanel x:Name="ViewGesturePanel"/>
        </Grid>

        <ToggleButton Width="150" Height="40" Content="{Binding ProjectionName}" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding MercatorOK}"/>
    </Grid>
</Window>
       